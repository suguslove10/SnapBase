# Database
DB_USER=dbbackup
DB_PASSWORD=dbbackup
DB_NAME=dbbackup

# AES-256 encryption key — MUST be exactly 32 bytes
# Generate: openssl rand -hex 16 | tr -d '\n'  (gives 32 hex chars = 32 bytes)
ENCRYPTION_KEY=change-me-to-32-byte-secret-key!

# JWT
JWT_SECRET=change-me-in-production

# MinIO / S3 storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=backups

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@snapbase.local
NOTIFICATIONS_ENABLED=false

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000

# Billing (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_ANNUAL=
RAZORPAY_PLAN_TEAM_MONTHLY=
RAZORPAY_PLAN_TEAM_ANNUAL=
RAZORPAY_PLAN_BUSINESS_MONTHLY=
RAZORPAY_PLAN_BUSINESS_ANNUAL=
RAZORPAY_PLAN_STORAGE_50GB=
RAZORPAY_PLAN_STORAGE_100GB=

# AI schema insights (optional)
OPENAI_API_KEY=
